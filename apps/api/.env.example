ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
API_VERSION=v1

API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

DATABASE_URL=postgresql://user:password@localhost:5432/ai_agents
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-agents-platform

TELEGRAM_BOT_TOKEN=
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_URL=

STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=AI Agents

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

FEATURE_ENABLE_STRIPE=true
FEATURE_ENABLE_TELEGRAM=true
FEATURE_ENABLE_SEO_AGENT=true
FEATURE_ENABLE_SUPPLIER_AGENT=true
FEATURE_ENABLE_PRODUCT_AGENT=true
FEATURE_ENABLE_PRICING_AGENT=true

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
