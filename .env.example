# ===================================
# AI Business SaaS Platform
# Environment Variables Template
# ===================================

# === GENERAL ===
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info
API_VERSION=v1

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=AI Agents Platform
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.com

# === BACKEND API ===
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
WORKERS=4

# === DATABASE ===
DATABASE_URL=postgresql://user:password@db:5432/ai_agents
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# === REDIS ===
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://redis:6379/1

# === JWT AUTH ===
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

# === OPENAI ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# === LANGCHAIN ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langchain-key
LANGCHAIN_PROJECT=ai-agents-platform

# === TELEGRAM ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_API_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook

# === STRIPE ===
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# === EMAIL ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=AI Agents Platform

# === AWS (optional) ===
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-agents-storage

# === MONITORING ===
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

# === ADMIN ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# === FEATURES ===
FEATURE_ENABLE_STRIPE=true
FEATURE_ENABLE_TELEGRAM=true
FEATURE_ENABLE_SEO_AGENT=true
FEATURE_ENABLE_SUPPLIER_AGENT=true
FEATURE_ENABLE_PRODUCT_AGENT=true
FEATURE_ENABLE_PRICING_AGENT=true

# === RATE LIMITING ===
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# === SECURITY ===
ALLOWED_HOSTS=localhost,127.0.0.1
SECURE_COOKIES=false
SECURE_HSTS=false
